{"openapi":"3.0.0","paths":{"/v1/contacts":{"post":{"description":"Create a new contact in your organization. At least one of phone_number, email, or whatsapp_id is required.","operationId":"ContactsV1Controller_create_v1","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateContactDto"}}}},"responses":{"201":{"description":"Contact created successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ContactSummaryDto"}}}},"400":{"description":"Bad request - validation failed"},"401":{"description":"Unauthorized - invalid API key"},"409":{"description":"Conflict - contact already exists"}},"security":[{"bearer":[]}],"summary":"Create a new contact","tags":["Contacts"]},"get":{"description":"Retrieve a paginated list of contacts. Supports search and filtering.","operationId":"ContactsV1Controller_findAll_v1","parameters":[{"name":"has_channel","required":false,"in":"query","schema":{"type":"string","enum":["SMS","WhatsApp","Email","WebChat"]}},{"name":"tag_ids","required":false,"in":"query","schema":{"type":"array","items":{"type":"number"}}},{"name":"audience_ids","required":false,"in":"query","schema":{"type":"array","items":{"type":"number"}}},{"name":"created_after","required":false,"in":"query","schema":{"type":"string"}},{"name":"created_before","required":false,"in":"query","schema":{"type":"string"}},{"name":"after","required":false,"in":"query","schema":{"type":"string"}},{"name":"limit","required":false,"in":"query","schema":{"minimum":1,"maximum":100,"default":50,"type":"number"}}],"responses":{"200":{"description":"List of contacts","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ListContactsServiceResponseDto"}}}},"401":{"description":"Unauthorized - invalid API key"}},"security":[{"bearer":[]}],"summary":"List contacts","tags":["Contacts"]}},"/v1/contacts/{id}":{"get":{"description":"Retrieve detailed information about a specific contact.","operationId":"ContactsV1Controller_findOne_v1","parameters":[{"name":"id","required":true,"in":"path","description":"Contact ID","schema":{"type":"number"}}],"responses":{"200":{"description":"Contact details","content":{"application/json":{"schema":{"$ref":"#/components/schemas/FullContactDto"}}}},"401":{"description":"Unauthorized - invalid API key"},"404":{"description":"Contact not found"}},"security":[{"bearer":[]}],"summary":"Get contact by ID","tags":["Contacts"]},"patch":{"description":"Update an existing contact. Only provided fields will be updated.","operationId":"ContactsV1Controller_update_v1","parameters":[{"name":"id","required":true,"in":"path","description":"Contact ID","schema":{"type":"number"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdateContactDto"}}}},"responses":{"200":{"description":"Contact updated successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ContactSummaryDto"}}}},"401":{"description":"Unauthorized - invalid API key"},"404":{"description":"Contact not found"}},"security":[{"bearer":[]}],"summary":"Update contact","tags":["Contacts"]},"delete":{"description":"Permanently delete a contact. This action cannot be undone.","operationId":"ContactsV1Controller_delete_v1","parameters":[{"name":"id","required":true,"in":"path","description":"Contact ID","schema":{"type":"number"}}],"responses":{"204":{"description":"Contact deleted successfully"},"401":{"description":"Unauthorized - invalid API key"},"404":{"description":"Contact not found"}},"security":[{"bearer":[]}],"summary":"Delete contact","tags":["Contacts"]}},"/v1/messages":{"post":{"description":"Send a message through a channel. Requires either contact_id or to (phone/email). Requires either body or template_id.","operationId":"MessagesV1Controller_send_v1","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/SendMessageDto"}}}},"responses":{"201":{"description":"Message queued for delivery","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MessageDto"}}}},"400":{"description":"Bad request - missing required fields"},"401":{"description":"Unauthorized - invalid API key"},"403":{"description":"Forbidden - insufficient scope"},"429":{"description":"Too many requests - rate limit exceeded"}},"security":[{"bearer":[]}],"summary":"Send a message","tags":["Messages"]}},"/v1/conversations":{"get":{"description":"Retrieve a paginated list of conversations. Supports filtering by status, contact, and channel.","operationId":"ConversationsV1Controller_findAll_v1","parameters":[{"name":"limit","required":false,"in":"query","description":"Number of results (default: 20, max: 100)","schema":{"minimum":1,"maximum":100,"default":20,"type":"number"}},{"name":"after","required":false,"in":"query","description":"Cursor for pagination","schema":{"type":"string"}},{"name":"status","required":false,"in":"query","description":"Filter by conversation status (open, closed, snoozed)","schema":{"type":"string","enum":["open","closed","archived"]}},{"name":"contact_id","required":false,"in":"query","description":"Filter by contact ID","schema":{"type":"number"}},{"name":"channel_id","required":false,"in":"query","description":"Filter by channel ID","schema":{"type":"number"}}],"responses":{"200":{"description":"List of conversations with pagination","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ConversationListResponseDto"}}}},"401":{"description":"Unauthorized - invalid API key"}},"security":[{"bearer":[]}],"summary":"List conversations","tags":["Conversations"]}},"/v1/conversations/{id}":{"get":{"description":"Retrieve detailed information about a specific conversation including contact and channel details.","operationId":"ConversationsV1Controller_findOne_v1","parameters":[{"name":"id","required":true,"in":"path","description":"Conversation ID","schema":{"type":"number"}}],"responses":{"200":{"description":"Conversation details","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ConversationDto"}}}},"401":{"description":"Unauthorized - invalid API key"},"404":{"description":"Conversation not found"}},"security":[{"bearer":[]}],"summary":"Get conversation by ID","tags":["Conversations"]}},"/v1/conversations/{id}/messages":{"get":{"description":"Retrieve a paginated list of messages in a conversation, ordered by most recent first.","operationId":"ConversationsV1Controller_getMessages_v1","parameters":[{"name":"id","required":true,"in":"path","description":"Conversation ID","schema":{"type":"number"}},{"name":"limit","required":false,"in":"query","description":"Number of messages (default: 50, max: 100)","schema":{"minimum":1,"maximum":100,"default":50,"type":"number"}},{"name":"after","required":false,"in":"query","description":"Cursor for pagination","schema":{"type":"string"}}],"responses":{"200":{"description":"List of messages with pagination","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MessageListResponseDto"}}}},"401":{"description":"Unauthorized - invalid API key"},"404":{"description":"Conversation not found"}},"security":[{"bearer":[]}],"summary":"Get messages for a conversation","tags":["Conversations"]},"post":{"description":"Send an outbound message in an existing conversation. A closed conversation is automatically reopened.","operationId":"ConversationsV1Controller_reply_v1","parameters":[{"name":"id","required":true,"in":"path","description":"Conversation ID","schema":{"type":"number"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ReplyDto"}}}},"responses":{"201":{"description":"Reply queued for delivery","content":{"application/json":{"schema":{"$ref":"#/components/schemas/MessageDto"}}}},"400":{"description":"Bad request - missing body"},"401":{"description":"Unauthorized - invalid API key"},"403":{"description":