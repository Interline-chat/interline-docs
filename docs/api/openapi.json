":{"application/json":{"schema":{"$ref":"#/components/schemas/ConversationStatusResponseDto"}}}},"400":{"description":"Bad request - invalid status"},"401":{"description":"Unauthorized - invalid API key"},"403":{"description":"Forbidden - insufficient scope"},"404":{"description":"Conversation not found"},"429":{"description":"Too many requests"}},"security":[{"bearer":[]}],"summary":"Open or close a conversation","tags":["Conversations"]}},"/v1/conversations/{id}/assign":{"post":{"description":"Assign a conversation to a user, or pass a null assignee_user_id to unassign. Optionally move it to a different inbox.","operationId":"ConversationsV1Controller_assign_v1","parameters":[{"name":"id","required":true,"in":"path","description":"Conversation ID","schema":{"type":"number"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AssignConversationDto"}}}},"responses":{"200":{"description":"Updated assignment","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ConversationAssignmentResponseDto"}}}},"201":{"description":"","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ConversationAssignmentResponseDto"}}}},"401":{"description":"Unauthorized - invalid API key"},"403":{"description":"Forbidden - insufficient scope"},"404":{"description":"Conversation or assignee user not found"},"429":{"description":"Too many requests"}},"security":[{"bearer":[]}],"summary":"Assign or unassign a conversation","tags":["Conversations"]}},"/v1/conversations/{id}/comments":{"post":{"description":"Add an internal note to a conversation, optionally with rich-text blocks and user mentions. Comments are not sent to the contact.","operationId":"ConversationsV1Controller_addComment_v1","parameters":[{"name":"id","required":true,"in":"path","description":"Conversation ID","schema":{"type":"number"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AddCommentDto"}}}},"responses":{"201":{"description":"Comment added","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ConversationCommentResponseDto"}}}},"400":{"description":"Bad request - missing text"},"401":{"description":"Unauthorized - invalid API key"},"403":{"description":"Forbidden - insufficient scope"},"404":{"description":"Conversation not found"},"429":{"description":"Too many requests"}},"security":[{"bearer":[]}],"summary":"Add an internal comment","tags":["Conversations"]}},"/v1/channels":{"get":{"description":"Retrieve all active channels for your organization. Returns channel ID, name, type (whatsapp, email, etc.), and status.","operationId":"ChannelsV1Controller_findAll_v1","parameters":[],"responses":{"200":{"description":"List of channels","content":{"application/json":{"schema":{"$ref":"#/components/schemas/ChannelListResponseDto"}}}},"401":{"description":"Unauthorized - invalid API key"}},"security":[{"bearer":[]}],"summary":"List channels","tags":["Channels"]}},"/v1/templates":{"get":{"description":"Retrieve WhatsApp message templates. Templates must be approved by Meta before they can be used for sending messages.","operationId":"TemplatesV1Controller_findAll_v1","parameters":[{"name":"channel_id","required":false,"in":"query","description":"Filter by WhatsApp channel ID","schema":{"type":"number"}},{"name":"status","required":false,"in":"query","description":"Filter by status (APPROVED, PENDING, REJECTED)","schema":{"type":"string","enum":["DRAFT","PENDING","APPROVED","REJECTED","PAUSED","DISABLED"]}},{"name":"category","required":false,"in":"query","description":"Filter by category (MARKETING, UTILITY, AUTHENTICATION)","schema":{"type":"string","enum":["MARKETING","UTILITY","AUTHENTICATION"]}}],"responses":{"200":{"description":"List of templates","content":{"application/json":{"schema":{"$ref":"#/components/schemas/TemplateListResponseDto"}}}},"401":{"description":"Unauthorized - invalid API key"}},"security":[{"bearer":[]}],"summary":"List WhatsApp templates","tags":["Templates"]}},"/v1/webhooks":{"post":{"description":"Register a new webhook endpoint to receive event notifications. You can subscribe to specific events like message.received, conversation.created, etc.","operationId":"WebhooksV1Controller_create_v1","parameters":[],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CreateWebhookDto"}}}},"responses":{"201":{"description":"Webhook registered successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/WebhookDto"}}}},"400":{"description":"Bad request - invalid URL or events"},"401":{"description":"Unauthorized - invalid API key"}},"security":[{"bearer":[]}],"summary":"Register a webhook","tags":["Webhooks"]},"get":{"description":"Retrieve all registered webhooks for your organization.","operationId":"WebhooksV1Controller_findAll_v1","parameters":[],"responses":{"200":{"description":"List of webhooks","content":{"application/json":{"schema":{"$ref":"#/components/schemas/WebhookListResponseDto"}}}},"401":{"description":"Unauthorized - invalid API key"}},"security":[{"bearer":[]}],"summary":"List webhooks","tags":["Webhooks"]}},"/v1/webhooks/{id}":{"get":{"description":"Retrieve details of a specific webhook including its configuration and health status.","operationId":"WebhooksV1Controller_findOne_v1","parameters":[{"name":"id","required":true,"in":"path","description":"Webhook ID","schema":{"type":"number"}}],"responses":{"200":{"description":"Webhook details","content":{"application/json":{"schema":{"$ref":"#/components/schemas/WebhookDto"}}}},"401":{"description":"Unauthorized - invalid API key"},"404":{"description":"Webhook not found"}},"security":[{"bearer":[]}],"summary":"Get webhook by ID","tags":["Webhooks"]},"patch":{"description":"Update webhook configuration. You can change the URL, subscribed events, or enable/disable the webhook.","operationId":"WebhooksV1Controller_update_v1","parameters":[{"name":"id","required":true,"in":"path","description":"Webhook ID","schema":{"type":"number"}}],"requestBody":{"required":true,"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UpdateWebhookDto"}}}},"responses":{"200":{"description":"Webhook updated successfully","content":{"application/json":{"schema":{"$ref":"#/components/schemas/WebhookDto"}}}},"400":{"description":"Bad request - invalid data"},"401":{"description":"Unauthorized - invalid API key"},"404":{"description":"Webhook not found"}},"security":[{"bearer":[]}],"summary":"Update webhook","tags":["Webhooks"]},"delete":{"description":"Permanently delete a webhook. This will stop all future event deliveries to this endpoint.","operationId":"WebhooksV1Controller_remove_v1","parameters":[{"name":"id","required":true,"in":"path","description":"Webhook ID","schema":{"type":"number"}}],"responses":{"204":{"description":"Webhook deleted successfully"},"401":{"description":"Unauthorized - invalid API key"},"404":{"description":"Webhook not found"}},"security":[{"bearer":[]}],"summary":"Delete webhook","tags":["Webhooks"]}},"/v1/webhooks/{id}/deliveries":{"get":{"description":"Retrieve recent delivery attempts for a webhook. Useful for debugging failed deliveries.","operationId":"WebhooksV1Controller_getDeliveries_v1","parameters":[{"name":"id","required":true,"in":"path","description":"Webhook ID","schema":{"type":"number"}}],"responses":{"200":{"description":"List of delivery attempts","content":{"application/json":{"schema":{"$ref":"#/components/schemas/WebhookDeliveryListResponseDto"}}}},"401":{"description":"Unauthorized - invalid API key"},"404":{"description":"Webhook not found"}},"security":[{"bearer":[]}],"summary":"Get webhook delivery history","tags":["Webhooks"]}},"/v1/users":{"get":{"description":"Retrieve a paginated list of the members of your organization. Removed members are excluded. Use these IDs to resolve `assigned_user_id` on conversations, or to pick an `assignee_user_id` when assigning.","operationId":"UsersV1Controller_findAll_v1","parameters":[{"name":"role","required":false,"in":"query","description":"Filter by organization role (admin, manager, agent)","schema":{"type":"string","enum":["admin","manager","agent"]}},{"name":"status","required":false,"in":"query","description":"Filter by user status (active, inactive, disabled)","schema":{"type":"string","enum":["active","inactive","disabled"]}},{"name":"after","required":false,"in":"query","description":"Cursor for pagination","schema":{"type":"string"}},{"name":"limit","required":false,"in":"query","description":"Number of results (default: 50, max: 100)","schema":{"minimum":1,"maximum":100,"default":50,"type":"number"}}],"responses":{"200":{"description":"List of users with pagination","content":{"application/json":{"schema":{"$ref":"#/components/schemas/UserListResponseDto"}}}},"401":{"description":"Unauthorized - invalid API key"},"403":{"description":"Forbidden - API key lacks the users:read scope"},"429":{"description":"Rate limit exceeded"}},"security":[{"bearer":[]}],"summary":"List users","tags":["Users"]}},"/v1/users/{id}":{"get":{"description":"Retrieve a single member of your organization. Returns 404 if the user is not an active member of your organization.","operationId":"UsersV1Controller_findOne_v1","parameters":[{"name":"id","required":true,"in":"path","description":"User ID","schema":{"type":"number"}}],"responses":{"200":{"description":"User details","content":{"application/json":{"schema":{"$ref":"#/components/schemas/UserDto"}}}},"401":{"description":"Unauthorized - invalid API key"},"403":{"description":"Forbidden - API key lacks the users:read scope"},"404":{"description":"User not found"},"429":{"description":"Rate limit exceeded"}},"security":[{"bearer":[]}],"summary":"Get user by ID","tags":["Users"]}}},"info":{"title":"Interline Public API","description":"\n## Overview\n\nThe Interline Public API allows you to programmatically send messages, manage contacts, read conversations, and receive real-time webhook notifications.\n\nThis page documents **only** `/v1/...` routes. It is published for customers at [help.interline.chat/api/reference](https://help.interline.chat/api/reference/), rebuilt from this spec on every production deploy. The full authenticated product API (JWT) is internal, and documented separately on the app host at `/api/reference`.\n\n## Authentication\n\nAll API requests require an API key, passed as a Bearer token:\n\n```\nAuthorization: Bearer ilc_live_your_api_key_here\n```\n\nYou can create and manage API keys in the Interline dashboard under Settings > API Keys.\n\n## Rate Limiting\n\nAuthenticated requests are rate limited per endpoint, based on the HTTP method:\n\n- Read requests (`GET`, `HEAD`): 120 requests per minute per API key\n- Write requests (everything else): 30 requests per minute per API key\n\nSome endpoints set a stricter limit than these defaults; check the endpoint's documentation for its specific limit.\n\nAuthenticated limits are enforced at two levels — per API key, and per organization across all of that organization's API keys combined. The organization ceiling scales with the org's subscription plan, so it is always a multiple of the per-key limit. Requests without a valid API key are additionally limited per IP address before authentication.\n\nRate limit headers are included in every response, reflecting whichever applicable limit is closest to being reached:\n\n- `X-RateLimit-Limit`: Maximum requests per minute for the binding scope\n- `X-RateLimit-Remaining`: Remaining requests in current window\n- `X-RateLimit-Reset`: Unix timestamp when the limit resets\n- `Retry-After`: Seconds to wait before retrying (sent only on `429` responses)\n\n## Scopes\n\nAPI keys can be restricted to specific scopes:\n\n| Scope | Description |\n|-------|-------------|\n| `messages:read` | Read message status and content |\n| `messages:write` | Send messages |\n| `contacts:read` | List and view contacts |\n| `contacts:write` | Create and update contacts |\n| `conversations:read` | List and view conversations |\n| `conversations:write` | Open, close, assign, comment on, and reply to conversations |\n| `channels:read` | List available channels |\n| `templates:read` | List WhatsApp templates |\n| `webhooks:read` | List registered webhooks |\n| `webhooks:write` | Create and delete webhooks |\n| `users:read` | List and view organization members |\n\n## Errors\n\nAll errors follow a consistent format:\n\n```json\n{\n  \"error\": \"error_code\",\n  \"message\": \"Human-readable description\",\n  \"statusCode\": 400\n}\n```\n\n| Status | Error Code | Description |\n|--------|-----------|-------------|\n| 400 | `bad_request` | Invalid request body or parameters |\n| 401 | `unauthorized` | Missing or invalid API key |\n| 403 | `insufficient_scope` | API key lacks required scope |\n| 404 | `not_found` | Resource not found |\n| 429 | `rate_limit_exceeded` | Too many requests |\n| 500 | `internal_error` | Server error |\n","version":"1.0","contact":{}},"tags":[{"name":"Messages","description":"Send and retrieve messages"},{"name":"Contacts","description":"Manage contacts"},{"name":"Conversations","description":"View conversations and message history; open, close, assign, comment, and reply"},{"name":"Channels","description":"List available messaging channels"},{"name":"Templates","description":"WhatsApp message templates"},{"name":"Webhooks","description":"Configure webhook notifications"}],"servers":[{"url":"https://api.interline.chat","description":"Production"},{"url":"http://localhost:3000","description":"Local Development"}],"components":{"securitySchemes":{"bearer":{"scheme":"bearer","bearerFormat":"JWT","type":"http","description":"API key, e.g. `Authorization: Bearer ilc_live_...`"}},"schemas":{"CreateContactDto":{"type":"object","properties":{"first_name":{"type":"string","maxLength":100},"last_name":{"type":"string","maxLength":100},"email":{"type":"string","format":"email"},"phone_number":{"type":"string","maxLength":50},"whatsapp_id":{"type":"string","maxLength":50},"profile_image":{"type":"string"},"address_line1":{"type":"string","maxLength":255},"address_line2":{"type":"string","maxLength":255},"city":{"type":"string","maxLength":100},"state":{"type":"string","maxLength":100},"postal_code":{"type":"string","maxLength":20},"country":{"type":"string","maxLength":100},"company_name":{"type":"string"},"notes":{"type":"string"},"preferred_channel_id":{"type":"number"},"tags":{"type":"array","items":{"type":"number"}},"audiences":{"type":"array","items":{"type":"number"}},"custom_fields":{"type":"object"}},"required":["first_name"]},"ContactSummaryDto":{"type":"object","properties":{"id":{"type":"number"},"first_name":{"type":"string"},"last_name":{"type":"string"},"email":{"type":"string","nullable":true},"phone_number":{"type":"string","nullable":true},"whatsapp_id":{"type":"string","nullable":true},"profile_image":{"type":"string","nullable":true},"last_contact_date":{"type":"string","nullable":true},"tags":{"type":"array","items":{"type":"number"}},"audiences":{"type":"array","items":{"type":"number"}},"address_line1":{"type":"string","nullable":true},"address_line2":{"type":"string","nullable":true},"city":{"type":"string","nullable":true},"state":{"type":"string","nullable":true},"postal_code":{"type":"string","nullable":true},"country":{"type":"string","nullable":true},"company_name":{"type":"string","nullable":true},"notes":{"type":"string","nullable":true},"created_at":{"type":"string"},"custom_fields":{"type":"object"}},"required":["id","first_name","last_name","email","phone_number","whatsapp_id","profile_image","last_contact_date","tags","address_line1","address_line2","city","state","postal_code","country","company_name","notes","created_at"]},"ListContactsServiceResponseDto":{"type":"object","properties":{"data":{"type":"array","items":{"$ref":"#/components/schemas/ContactSummaryDto"}},"nextCursor"